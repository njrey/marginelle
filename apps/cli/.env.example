# Required: WebSocket URL for the LiveStore Cloudflare sync server
# Production example: wss://websocket-server.YOUR_ACCOUNT.workers.dev
# Local dev example:  ws://localhost:8787
MARGINELLE_SYNC_URL=wss://websocket-server.YOUR_ACCOUNT.workers.dev

# Optional: HTTP base URL for BetterAuth (defaults to MARGINELLE_SYNC_URL with https://)
# MARGINELLE_AUTH_URL=https://websocket-server.YOUR_ACCOUNT.workers.dev
